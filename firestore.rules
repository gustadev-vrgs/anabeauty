rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    function isCreatingOwnDocument() {
      return isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }

    function hasBaseAuditFields() {
      return request.resource.data.keys().hasAll(['ownerId', 'createdAt', 'updatedAt']);
    }

    function canReadWriteOwnDocument() {
      return isOwner() || isCreatingOwnDocument();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow create: if isAuthenticated() && userId == request.auth.uid && request.resource.data.role in ['admin', 'professional'];
      allow update: if isAuthenticated() && userId == request.auth.uid;
      allow delete: if false;
    }

    match /{collectionName}/{documentId} {
      allow read: if isOwner();
      allow create: if isCreatingOwnDocument() && hasBaseAuditFields();
      allow update: if isOwner();
      allow delete: if isOwner();
    }
  }
}
